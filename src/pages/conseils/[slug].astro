---
import { getCollection, render } from 'astro:content';
import CtaBanner from '../../components/CtaBanner.astro';
import { SITE } from '../../config/site';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('conseils');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const pageUrl = `${SITE.url}/conseils/${post.id}`;
const formatDate = (d: Date) =>
  d.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' });

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString().split('T')[0],
  inLanguage: 'fr-CA',
  mainEntityOfPage: pageUrl,
  author: { '@type': 'Organization', name: SITE.name },
  publisher: { '@id': `${SITE.url}/#garage` },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Conseils', item: `${SITE.url}/conseils` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: pageUrl },
  ],
};
---

<BaseLayout title={`${post.data.title} | Garage Yanexpro`} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <section class="section-dark">
    <div class="container page-hero">
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href="/">Accueil</a>
        <span aria-hidden="true">/</span>
        <a href="/conseils">Conseils</a>
      </nav>
      <p class="post-date">{formatDate(post.data.pubDate)}</p>
      <h1 class="page-title">{post.data.title}</h1>
    </div>
  </section>

  <article class="container prose">
    <Content />
  </article>

  <section class="container article-cta">
    <CtaBanner
      title="Une question sur votre véhicule?"
      subtitle="Appelez-nous, notre équipe vous répond du lundi au vendredi."
    />
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: 56px;
    padding-bottom: 72px;
  }

  .page-hero :global(.page-title) {
    max-width: 760px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: rgba(246, 246, 244, 0.65);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--paper);
  }

  .breadcrumb span[aria-hidden] {
    color: rgba(246, 246, 244, 0.35);
  }

  .post-date {
    margin: 0 0 12px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--red-soft);
  }

  /* ===== Mise en forme du contenu markdown ===== */

  .prose {
    max-width: calc(760px + var(--gutter) * 2);
    padding-top: 56px;
    padding-bottom: 16px;
  }

  .prose :global(p) {
    margin: 0 0 22px;
    font-size: 17px;
    line-height: 1.75;
    color: var(--gray-1);
  }

  .prose :global(h2) {
    margin: 40px 0 16px;
    font-size: clamp(22px, 3vw, 27px);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .prose :global(h3) {
    margin: 30px 0 12px;
    font-size: 19px;
    font-weight: 800;
    color: var(--ink);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 22px;
    padding-left: 24px;
  }

  .prose :global(li) {
    margin-bottom: 10px;
    font-size: 16.5px;
    line-height: 1.7;
    color: var(--gray-1);
  }

  .prose :global(a) {
    color: var(--red);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(strong) {
    color: var(--ink);
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--card-border);
    margin: 36px 0;
  }

  .article-cta {
    padding-top: 40px;
    padding-bottom: 80px;
    max-width: calc(760px + var(--gutter) * 2);
  }

  @media (max-width: 960px) {
    .prose {
      padding-top: 40px;
    }

    .article-cta {
      padding-bottom: 56px;
    }
  }
</style>
