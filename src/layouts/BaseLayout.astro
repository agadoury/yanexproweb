---
import '@fontsource-variable/archivo';
import '@fontsource-variable/archivo/wght-italic.css';
import '../styles/global.css';

import ConsentAnalytics from '../components/ConsentAnalytics.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import TireBanner from '../components/TireBanner.astro';
import { SITE } from '../config/site';

interface Props {
  title: string;
  description: string;
  /** Exclut la page des moteurs de recherche (page de confirmation, etc.). */
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname.replace(/\.html$/, ''), Astro.site);

/** Données structurées schema.org — fiche d'entreprise locale (AutoRepair). */
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  '@id': `${SITE.url}/#garage`,
  name: SITE.name,
  alternateName: 'Yanexpro Mécanique Auto',
  description: SITE.description,
  url: SITE.url,
  logo: `${SITE.url}/images/logo-yanexpro.png`,
  image: `${SITE.url}/images/og-image.png`,
  telephone: SITE.phone.e164,
  email: SITE.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.province,
    postalCode: SITE.address.postalCode,
    addressCountry: SITE.address.country,
  },
  openingHoursSpecification: SITE.openingHoursSpecification,
  founder: {
    '@type': 'Person',
    name: SITE.owner,
  },
  memberOf: {
    '@type': 'Organization',
    name: 'Réseau UniPro',
  },
  knowsAbout: [
    'Freins et freins antiblocage (ABS)',
    'Véhicules électriques',
    'Silencieux et échappement',
    'Direction et suspension',
    'Injection et électricité',
    'Refroidissement et air climatisé',
    'Alignement',
    'Électronique et mise au point',
    'Vente et pose de pneus',
  ],
  areaServed: [...SITE.areasServed, 'Rive-Sud de Montréal', 'Montérégie'],
  priceRange: '$$',
  inLanguage: 'fr-CA',
};
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {
      SITE.googleSiteVerification && (
        <meta name="google-site-verification" content={SITE.googleSiteVerification} />
      )
    }
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="64x64" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#14161A" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:image" content={new URL('/images/og-image.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`Logo ${SITE.name}`} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Vercel Web Analytics et Speed Insights — actifs seulement en production. */}
    {import.meta.env.PROD && <script is:inline defer src="/_vercel/insights/script.js" />}
    {
      import.meta.env.PROD && (
        <script
          is:inline
          set:html={`window.si = window.si || function () { (window.siq = window.siq || []).push(arguments); };`}
        />
      )
    }
    {import.meta.env.PROD && <script is:inline defer src="/_vercel/speed-insights/script.js" />}
  </head>
  <body>
    <a href="#contenu" class="skip-link">Aller au contenu</a>
    <div class="page-shell">
      <TireBanner />
      <Header />
      <main id="contenu">
        <slot />
      </main>
      <Footer />
    </div>
    <MobileCallBar />
    {import.meta.env.PROD && <ConsentAnalytics />}

    <script>
      // Apparition en douceur des cartes au défilement (une seule fois).
      const items = document.querySelectorAll('main .card, main .review-card');
      if (items.length && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('reveal-in');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -40px 0px', threshold: 0.1 }
        );
        items.forEach((el) => {
          const siblings = el.parentElement ? Array.from(el.parentElement.children) : [];
          const index = Math.max(0, siblings.indexOf(el));
          (el as HTMLElement).style.setProperty('--reveal-delay', `${Math.min(index % 6, 4) * 60}ms`);
          el.classList.add('reveal-init');
          io.observe(el);
        });
      }
    </script>
  </body>
</html>

<style>
  .page-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }
</style>
