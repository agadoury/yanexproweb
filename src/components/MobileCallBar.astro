---
import { SITE } from '../config/site';

/**
 * Boutons flottants (mobile seulement), ancrés en bas à droite :
 * appeler ou demander un rendez-vous, toujours à portée de pouce.
 */
---

<div class="call-fabs">
  <a href="/rendez-vous" class="call-fabs__book">Rendez-vous</a>
  <a href={SITE.phone.href} class="call-fabs__call">
    <span aria-hidden="true">☎</span>
    <span>Appelez-nous</span>
  </a>
</div>

<style>
  .call-fabs {
    display: none;
  }

  @media (max-width: 960px) {
    .call-fabs {
      position: fixed;
      right: 16px;
      bottom: calc(16px + env(safe-area-inset-bottom));
      z-index: 60;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 10px;
      /* Masqués au chargement; apparaissent au défilement */
      opacity: 0;
      transform: translateY(16px);
      pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .call-fabs--visible {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }

    .call-fabs__call,
    .call-fabs__book {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 22px;
      border-radius: 999px;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.28);
    }

    .call-fabs__call {
      background: var(--red);
      color: #fff;
    }

    .call-fabs__book {
      background: var(--ink);
      color: var(--paper);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .call-fabs {
      transition: none;
    }
  }
</style>

<script>
  // Affiche les boutons flottants seulement après un début de défilement.
  const fabs = document.querySelector('.call-fabs');
  const THRESHOLD = 150;
  let ticking = false;

  function update() {
    fabs?.classList.toggle('call-fabs--visible', window.scrollY > THRESHOLD);
    ticking = false;
  }

  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    },
    { passive: true }
  );
  update();
</script>
