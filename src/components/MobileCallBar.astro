---
import { SITE } from '../config/site';

/**
 * Barre d'appel fixée au bas de l'écran sur mobile : appeler ou
 * demander un rendez-vous, toujours à portée de pouce.
 */
---

<div class="call-bar">
  <a href={SITE.phone.href} class="call-bar__call">
    <span aria-hidden="true">☎</span>
    <span>Appelez-nous</span>
  </a>
  <a href="/rendez-vous" class="call-bar__book">Rendez-vous</a>
</div>

<style>
  .call-bar {
    display: none;
  }

  @media (max-width: 960px) {
    .call-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 60;
      display: flex;
      gap: 1px;
      background: rgba(20, 22, 26, 0.35);
      padding-bottom: env(safe-area-inset-bottom);
      box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.18);
    }

    .call-bar__call,
    .call-bar__book {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 16px 12px;
      font-size: 16px;
      font-weight: 700;
      text-decoration: none;
    }

    .call-bar__call {
      background: var(--red);
      color: #fff;
    }

    .call-bar__book {
      background: var(--ink);
      color: var(--paper);
    }
  }
</style>
