---
import { SITE } from '../config/site';

interface Props {
  /** Variante claire pour fond sombre (pied de page). */
  dark?: boolean;
}

const { dark = false } = Astro.props;
const src = dark ? '/images/logo-yanexpro-clair.png' : '/images/logo-yanexpro.png';
---

<img
  src={src}
  alt={`${SITE.shortName} — ${SITE.tagline}`}
  width="300"
  height="192"
  class:list={['logo', { 'logo--footer': dark }]}
/>

<style>
  .logo {
    height: 62px;
    width: auto;
    display: block;
  }

  .logo--footer {
    height: 96px;
  }

  @media (max-width: 960px) {
    .logo {
      height: 54px;
    }

    .logo--footer {
      height: 88px;
    }
  }
</style>
