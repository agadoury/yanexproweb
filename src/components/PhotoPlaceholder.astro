---
/**
 * Bloc hachuré en attente d'une vraie photo.
 * Remplacez-le par une balise <img> ou <Image> quand les photos sont prêtes.
 */
interface Props {
  label: string;
  ratio?: string;
  dark?: boolean;
  minHeight?: string;
}

const { label, ratio, dark = false, minHeight } = Astro.props;
---

<div
  class:list={['photo-placeholder', { 'photo-placeholder--dark': dark }]}
  style={`${ratio ? `aspect-ratio: ${ratio};` : ''}${minHeight ? `min-height: ${minHeight};` : ''}`}
  role="img"
  aria-label={label}
>
  <span>{label}</span>
</div>

<style>
  .photo-placeholder {
    background: repeating-linear-gradient(45deg, #e9e9e5 0 14px, #f1f1ee 14px 28px);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 16px;
  }

  .photo-placeholder span {
    font-family: var(--mono);
    font-size: 13px;
    color: #9a9c99;
  }

  .photo-placeholder--dark {
    background: repeating-linear-gradient(45deg, #22252b 0 14px, #1b1e23 14px 28px);
    border-color: var(--light-border);
  }

  .photo-placeholder--dark span {
    color: rgba(246, 246, 244, 0.45);
  }
</style>
