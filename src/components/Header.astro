---
import { NAV_LINKS, SITE } from '../config/site';
import Logo from './Logo.astro';

const currentPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

/** « Rendez-vous » devient un bouton d'action à droite; il sort de la liste
 *  de navigation du bureau (il reste dans le menu mobile et le pied de page). */
const desktopLinks = NAV_LINKS.filter((link) => link.href !== '/rendez-vous');
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${SITE.name}, accueil`}>
      <Logo />
    </a>

    <nav class="site-nav" aria-label="Navigation principale">
      {
        desktopLinks.map((link) => (
          <a
            href={link.href}
            class:list={['site-nav__link', { 'site-nav__link--active': isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="site-header__actions">
      <a
        href="/rendez-vous"
        class:list={['site-header__book', { 'site-header__book--active': isActive('/rendez-vous') }]}
      >
        Rendez-vous
      </a>
      <a href={SITE.phone.href} class="site-header__phone">
        <span aria-hidden="true">☎</span>
        <span>{SITE.phone.display}</span>
      </a>
    </div>

    <button
      class="site-header__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Ouvrir le menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Navigation mobile" hidden>
    {
      NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={['mobile-nav__link', { 'mobile-nav__link--active': isActive(link.href) }]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))
    }
    <a href={SITE.phone.href} class="mobile-nav__phone">☎ {SITE.phone.display}</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .site-header--scrolled {
    border-bottom-color: var(--card-border);
    box-shadow: 0 2px 14px rgba(20, 22, 26, 0.06);
  }

  .site-header__inner {
    height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .site-header__brand {
    text-decoration: none;
    flex: none;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .site-nav__link {
    text-decoration: none;
    font-size: 15px;
    padding: 10px 14px;
    border-radius: 6px;
    color: var(--gray-1);
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .site-nav__link:hover {
    color: var(--red);
  }

  .site-nav__link--active {
    color: var(--red);
    font-weight: 700;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .site-header__book {
    display: inline-flex;
    align-items: center;
    height: 44px;
    color: var(--ink);
    text-decoration: none;
    font-weight: 700;
    font-size: 15px;
    padding: 0 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.22);
    border-radius: 6px;
    white-space: nowrap;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .site-header__book:hover,
  .site-header__book--active {
    border-color: var(--red);
    color: var(--red);
  }

  .site-header__phone {
    display: flex;
    align-items: center;
    height: 44px;
    gap: 10px;
    background: var(--red);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 15px;
    padding: 0 22px;
    border-radius: 6px;
    white-space: nowrap;
    transition: background-color 0.15s ease;
  }

  .site-header__phone:hover {
    background: var(--red-dark);
  }

  /* ===== Bouton hamburger ===== */

  .site-header__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    background: none;
    border: 1px solid var(--card-border);
    border-radius: 6px;
    cursor: pointer;
  }

  .site-header__toggle span {
    display: block;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .site-header__toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .site-header__toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }

  .site-header__toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ===== Menu mobile ===== */

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px var(--gutter) 20px;
    border-top: 1px solid var(--card-border);
    background: #fff;
  }

  .mobile-nav__link {
    text-decoration: none;
    font-size: 17px;
    font-weight: 600;
    color: var(--gray-1);
    padding: 14px 4px;
    border-bottom: 1px solid var(--card-border);
  }

  .mobile-nav__link--active {
    color: var(--red);
    font-weight: 700;
  }

  .mobile-nav__phone {
    margin-top: 18px;
    background: var(--red);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 16px;
    padding: 14px 22px;
    border-radius: 6px;
    text-align: center;
  }

  @media (max-width: 960px) {
    .site-nav,
    .site-header__actions {
      display: none;
    }

    .site-header__toggle {
      display: flex;
    }

    .mobile-nav:not([hidden]) {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.site-header__toggle');
  const menu = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Ouvrir le menu' : 'Fermer le menu');
    if (menu) menu.hidden = open;
  });

  // Ombre sous l'en-tête dès qu'on quitte le haut de page
  const header = document.querySelector('.site-header');
  const onScroll = () => header?.classList.toggle('site-header--scrolled', window.scrollY > 4);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
